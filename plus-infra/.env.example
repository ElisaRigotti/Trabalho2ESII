
# ─── Ports ───────────────────────────────────────────────────────────────────
MS_AUTH_PORT=3001
MFE_AUTH_PORT=4001
SHELL_PORT=3000
MS_REPORT_PORT=3009
MFE_REPORT_PORT=4009

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret

# ─── AWS / Ministack (LocalStack) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# ─── RDS (provisionado pelo Ministack, usado pelo plus-ms-auth) ───────────────
# Valores conforme README oficial do Grupo 7 (plus-ms-auth)
DB_HOST=ministack-rds-plus-auth-db
DB_PORT=5432
DB_USER=plus
DB_PASSWORD=plus_secret
DB_NAME=plus_auth

# ─── MS9 — Report Service (Grupo 23) ──────────────────────────────────────────
# USE_MOCKS=true: usa dados mockados quando os serviços dependentes
# (Pedidos, Estoque, Produto) ainda não estão prontos/integrados.
# Mude para "false" quando os três serviços reais estiverem disponíveis.
USE_MOCKS=true
ORDER_SERVICE_URL=http://plus-ms-ped:3007
STOCK_SERVICE_URL=http://plus-ms-estoque:3000
PRODUCT_SERVICE_URL=http://plus-ms-product:3002
